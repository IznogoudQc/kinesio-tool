{
  "name": "kinesio-tool",
  "version": "0.2.32",
  "description": "Application locale pour Marie-Eve kinésiologue",
  "main": "out/main/index.js",
  "author": "Kinésio Conseil",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && npm run build:standalone",
    "build:standalone": "vite build -c vite.standalone.config.ts && node scripts/inline-standalone.mjs",
    "dist": "npm run build && electron-builder",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.43.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "keytar": "^7.9.0",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.12.0",
    "nodemailer": "^6.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.7",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.30.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "eslint": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}

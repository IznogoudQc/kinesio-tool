# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-electron/
out/
release/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Environment
.env
.env.local
.env.*.local
!.env.example

# Données locales utilisateur (ne JAMAIS commit)
data/
*.db
*.db-journal
*.sqlite
*.sqlite3

# Obsidian (workspace personnel, garder le contenu mais pas les workspaces)
docs/.obsidian/workspace*
docs/.obsidian/cache
docs/.trash/

# Drizzle
drizzle/meta/_journal.json.bak

# Claude Code (local settings, pas partagées)
.claude/settings.local.json

# Fichiers de log de dev
dev-err.txt
dev-out.txt

# Fichiers de test (peuvent contenir des donnees client reelles)
test-files/

# Compilation artifacts TypeScript polluees (jamais dans src/ ni electron/)
src/**/*.js
src/**/*.d.ts
!src/env.d.ts
!src/vite-env.d.ts
electron/**/*.js
electron/**/*.d.ts

# Backups d'images originales (conservees en local seulement)
src/assets/*-original.png
src/assets/*.previous.png
src/assets/silhouettes-source.png

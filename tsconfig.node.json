{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "outDir": "out/main"
  },
  "include": [
    "electron/**/*",
    "db/**/*",
    "electron.vite.config.ts",
    "drizzle.config.ts",
    "src/lib/body-fat-calculator.ts",
    "src/lib/bilan-bounds.ts"
  ]
}
